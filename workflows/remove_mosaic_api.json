{
  "1": {
    "class_type": "VHS_LoadVideo",
    "inputs": {
      "video": "input.mp4",
      "force_rate": 0,
      "custom_width": 0,
      "custom_height": 0,
      "frame_load_cap": 0,
      "skip_first_frames": 0,
      "select_every_nth": 1,
      "format": "AnimateDiff"
    }
  },
  "2": {
    "class_type": "LadaLoadDetectionModel",
    "inputs": {
      "model_name": "lada_mosaic_detection_model_v4_accurate.pt",
      "device": "auto",
      "fp16": "auto"
    }
  },
  "3": {
    "class_type": "LadaLoadRestorationModel",
    "inputs": {
      "model_name": "lada_mosaic_restoration_model_generic_v1.2_full.pth",
      "device": "auto",
      "fp16": "auto"
    }
  },
  "4": {
    "class_type": "LadaRemoveMosaic",
    "inputs": {
      "images": ["1", 0],
      "detection_model": ["2", 0],
      "restoration_model": ["3", 0],
      "fps": 25.0,
      "max_clip_length": 180
    }
  },
  "5": {
    "class_type": "VHS_VideoCombine",
    "inputs": {
      "images": ["4", 0],
      "audio": ["1", 2],
      "frame_rate": 25,
      "loop_count": 0,
      "filename_prefix": "RemoveMosaic/output",
      "format": "video/h264-mp4",
      "pix_fmt": "yuv420p",
      "crf": 19,
      "save_metadata": true,
      "pingpong": false,
      "save_output": true
    }
  }
}
